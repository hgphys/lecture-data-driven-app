# Streamlit secrets template.
#
# Local dev:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   then paste the service-account JSON values below.
#   (or skip the file entirely — app/sheets.py falls back to
#   ../private/credentials/<key>.json automatically.)
#
# Streamlit Community Cloud:
#   Paste the same contents into the app's "Secrets" panel
#   (Settings → Secrets) in share.streamlit.io.

sheet_id = "REPLACE_WITH_SHEET_ID"

# Teacher dashboard password. Only the instructor should know this.
# User-side password is dynamic and stored in the workbook's "_config" sheet
# (editable from the teacher dashboard at runtime).
teacher_password = "REPLACE_WITH_TEACHER_PASSWORD"

[gcp_service_account]
type = "service_account"
project_id = "lecture-data-driven-app"
private_key_id = "REPLACE"
private_key = "-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----\n"
client_email = "lecture-data-driven-app@lecture-data-driven-app.iam.gserviceaccount.com"
client_id = "REPLACE"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "REPLACE"
universe_domain = "googleapis.com"
